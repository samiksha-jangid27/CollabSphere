NODE_ENV=development
# Local dev binds to 5001 (AirPlay blocks 5000 on macOS). Render injects PORT
# automatically in production, so do not set this variable on the host.
PORT=5001

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/collabsphere

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EMAIL_SECRET=your-email-secret-here

# JWT Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_EXPIRY=24h

# Twilio (optional in dev — OTP logs to console)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# SMTP (for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional — override the User-Agent header sent to Nominatim
GEOCODE_USER_AGENT=CollabSphere/1.0 (dev@collabsphere.local)

# Client origin. Used for CORS, Socket.io CORS, and email verification links.
# Set to the deployed frontend origin in production (e.g. https://collabsphere.vercel.app).
# No trailing slash.
CLIENT_URL=http://localhost:3000

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
